# Exemplo de .env para desenvolvimento
# Nunca commit este arquivo com valores reais em repositórios públicos

# Mercado Pago
# Obtenha estas chaves no painel do Mercado Pago (use as de teste em dev)
MP_ACCESS_TOKEN=TEST-REPLACE-MP-ACCESS-TOKEN
MP_PIX_KEY=REPLACE-MP-PIX-KEY

# Segredo compartilhado para verificar assinaturas HMAC dos webhooks
# Configure um valor forte e mantenha fora do repositório (use variáveis de ambiente no servidor)
WEBHOOK_SECRET=REPLACE_WITH_A_RANDOM_SECRET

# JWT secret para assinaturas (não comitar valor real)
JWT_SECRET=REPLACE_WITH_A_STRONG_SECRET

# Outros valores de configuração
#DB_HOST=localhost
#DB_USER=user
#DB_PASS=pass